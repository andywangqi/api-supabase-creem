{
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/route?path=admin-page"
    },
    {
      "source": "/admin",
      "destination": "/api/route?path=admin-page"
    },
    {
      "source": "/admin.html",
      "destination": "/api/route?path=admin-page"
    },
    {
      "source": "/admin/login",
      "destination": "/api/route?path=admin-login-page"
    },
    {
      "source": "/admin/login.html",
      "destination": "/api/route?path=admin-login-page"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/route?path=:path*"
    },
    {
      "source": "/payment-success",
      "destination": "/payment-success.html"
    },
    {
      "source": "/health",
      "destination": "/api/route?path=health"
    }
  ]
}
